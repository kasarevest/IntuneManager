# Jira polling credentials — copy to scripts/.env.jira and fill in your values.
# The polling script (check-jira-inprogress.ps1) loads this file automatically.
# Never commit scripts/.env.jira to git.

JIRA_BASE_URL=https://yoursite.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-api-token-here
JIRA_PROJECT=SCRUM

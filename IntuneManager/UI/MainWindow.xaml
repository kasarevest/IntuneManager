<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Intune App Manager"
    Width="1200" Height="750"
    MinWidth="900" MinHeight="550"
    WindowStartupLocation="CenterScreen"
    Background="#1E1E2E"
    FontFamily="Segoe UI"
    FontSize="13">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <!-- Styles loaded programmatically in Main.ps1 -->
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Title bar -->
            <RowDefinition Height="48"/>
            <!-- Main content -->
            <RowDefinition Height="*"/>
            <!-- Log dock -->
            <RowDefinition Height="180"/>
            <!-- Status bar -->
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>

        <!-- ===== Title Bar ===== -->
        <Border Grid.Row="0" Background="#16162A" Padding="16,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="⬡" FontSize="20" Foreground="#4F8EF7" Margin="0,0,10,0" VerticalAlignment="Center"/>
                    <TextBlock Text="Intune App Manager" FontSize="16" FontWeight="SemiBold"
                               Foreground="#E2E2F0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Connection status -->
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center" Margin="20,0">
                    <Ellipse x:Name="ConnectionDot" Width="8" Height="8" Margin="0,0,6,0"
                             Fill="#5A5A7A" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ConnectionLabel" Text="Not connected"
                               Foreground="#9999BB" FontSize="12" VerticalAlignment="Center"/>
                    <TextBlock x:Name="LastSyncLabel" Text="" Foreground="#5A5A7A"
                               FontSize="11" Margin="16,0,0,0" VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Top-right actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnSync" Content="↺  Sync Now"
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,5" Visibility="Collapsed" Margin="0,0,8,0"/>
                    <Button x:Name="BtnLogout" Content="Logout"
                            Style="{StaticResource SecondaryButton}"
                            Padding="10,5" Visibility="Collapsed"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Main Content (ContentHost swaps views) ===== -->
        <ContentControl x:Name="ContentHost" Grid.Row="1" Margin="0"/>

        <!-- ===== Log Dock ===== -->
        <Border Grid.Row="2" Background="#111120" BorderBrush="#3A3A55" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="28"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Log toolbar -->
                <Border Grid.Row="0" Background="#16162A" Padding="8,0">
                    <Grid>
                        <TextBlock Text="LOG" Foreground="#5A5A7A" FontSize="11" FontWeight="SemiBold"
                                   VerticalAlignment="Center" Margin="2,0"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Button x:Name="BtnClearLog" Content="Clear"
                                    Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="11" Margin="0,0,6,0"/>
                            <Button x:Name="BtnCopyLog" Content="Copy All"
                                    Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="11" Margin="0,0,6,0"/>
                            <Button x:Name="BtnSaveLog" Content="Save…"
                                    Style="{StaticResource SecondaryButton}" Padding="8,3" FontSize="11"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Log TextBox -->
                <TextBox x:Name="LogTextBox" Grid.Row="1"
                         Style="{StaticResource LogTextBox}"/>
            </Grid>
        </Border>

        <!-- ===== Status Bar ===== -->
        <Border Grid.Row="3" Background="#13132A" Padding="12,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusLabel" Grid.Column="0" Text="Ready"
                           Foreground="#9999BB" FontSize="11" VerticalAlignment="Center"/>
                <ProgressBar x:Name="ProgressBar" Grid.Column="1"
                             Width="160" Height="6" Minimum="0" Maximum="100" Value="0"
                             Margin="8,0" Foreground="#4F8EF7" Background="#3A3A55"
                             BorderThickness="0" Visibility="Collapsed" VerticalAlignment="Center"/>
                <Button x:Name="BtnCancel" Grid.Column="2" Content="Cancel"
                        Style="{StaticResource DangerButton}" Padding="8,3" FontSize="11"
                        Visibility="Collapsed"/>
            </Grid>
        </Border>
    </Grid>
</Window>

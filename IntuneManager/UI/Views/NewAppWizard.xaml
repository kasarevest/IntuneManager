<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <Border Grid.Row="0" Background="#1A1A2C" Padding="20,14" BorderBrush="#3A3A55" BorderThickness="0,0,0,1">
        <Grid>
            <StackPanel>
                <TextBlock Text="New App Wizard" FontSize="18" FontWeight="SemiBold" Foreground="#E2E2F0"/>
                <TextBlock Text="Create a new Intune Win32 application" FontSize="12" Foreground="#9999BB" Margin="0,2,0,0"/>
            </StackPanel>
            <Button x:Name="BtnBackWizard" Content="← Back to Dashboard"
                    Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>
    </Border>

    <!-- Step indicator -->
    <Border Grid.Row="1" Background="#16162A" Padding="20,10" BorderBrush="#3A3A55" BorderThickness="0,0,0,1">
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Border x:Name="Step1Indicator" CornerRadius="12" Width="24" Height="24"
                    Background="#4F8EF7">
                <TextBlock Text="1" Foreground="White" FontSize="11" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="Step1Label" Text="Select Source" Foreground="#4F8EF7"
                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="4,0,8,0"/>
            <TextBlock Text="------" Foreground="#3A3A55" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Border x:Name="Step2Indicator" CornerRadius="12" Width="24" Height="24"
                    Background="#3A3A55">
                <TextBlock Text="2" Foreground="#9999BB" FontSize="11" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="Step2Label" Text="Configure Metadata" Foreground="#9999BB"
                       FontSize="12" VerticalAlignment="Center" Margin="4,0,8,0"/>
            <TextBlock Text="------" Foreground="#3A3A55" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <Border x:Name="Step3Indicator" CornerRadius="12" Width="24" Height="24"
                    Background="#3A3A55">
                <TextBlock Text="3" Foreground="#9999BB" FontSize="11" FontWeight="Bold"
                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock x:Name="Step3Label" Text="Build + Upload" Foreground="#9999BB"
                       FontSize="12" VerticalAlignment="Center" Margin="4,0,0,0"/>
        </StackPanel>
    </Border>

    <!-- Step content area -->
    <ContentControl x:Name="WizardContent" Grid.Row="2"/>

    <!-- Footer nav buttons -->
    <Border Grid.Row="3" Background="#1A1A2C" Padding="20,12" BorderBrush="#3A3A55" BorderThickness="0,1,0,0">
        <Grid>
            <Button x:Name="BtnPrev" Content="← Previous" Style="{StaticResource SecondaryButton}"
                    HorizontalAlignment="Left" Visibility="Collapsed"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnCancelWizard" Content="Cancel" Style="{StaticResource SecondaryButton}" Margin="0,0,10,0"/>
                <Button x:Name="BtnNext" Content="Next ->" Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>
</Grid>

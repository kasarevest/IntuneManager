<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E">
    <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Toolbar -->
    <Border Grid.Row="0" Background="#1A1A2C" Padding="16,10" BorderBrush="#3A3A55" BorderThickness="0,0,0,1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                <TextBox x:Name="TxtSearch" Width="220" Height="30"
                         VerticalContentAlignment="Center" Margin="0,0,10,0"/>
                <ComboBox x:Name="CboFilter" Height="30" Width="150">
                    <ComboBoxItem Content="All Apps" IsSelected="True"/>
                    <ComboBoxItem Content="Update Available"/>
                    <ComboBoxItem Content="Current"/>
                    <ComboBoxItem Content="Not in Intune"/>
                    <ComboBoxItem Content="Cloud Only"/>
                </ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <Button x:Name="BtnUpdateAll" Content="▲  Update All Outdated"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,8,0"/>
                <Button x:Name="BtnNewApp" Content="+  New App"
                        Style="{StaticResource PrimaryButton}"/>
            </StackPanel>
        </Grid>
    </Border>

    <!-- App DataGrid -->
    <DataGrid x:Name="AppGrid" Grid.Row="1" Margin="0">
        <DataGrid.Columns>
            <DataGridTextColumn Header="Application"   Binding="{Binding DisplayName}"   Width="220"/>
            <DataGridTextColumn Header="Local Version" Binding="{Binding LocalVersion}"  Width="120"/>
            <DataGridTextColumn Header="Intune Version" Binding="{Binding IntuneVersion}" Width="120"/>
            <DataGridTemplateColumn Header="Status" Width="130">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <Border CornerRadius="4" Padding="6,2"
                                Background="{Binding StatusColor}" HorizontalAlignment="Left" Margin="4,0">
                            <TextBlock Text="{Binding StatusText}" FontSize="11" FontWeight="SemiBold"
                                       Foreground="White"/>
                        </Border>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
            <DataGridTextColumn Header="Publisher"     Binding="{Binding Publisher}"     Width="140"/>
            <DataGridTextColumn Header="Last Modified" Binding="{Binding LastModified}"  Width="120"/>
            <DataGridTemplateColumn Header="Action" Width="90">
                <DataGridTemplateColumn.CellTemplate>
                    <DataTemplate>
                        <Button Content="{Binding ActionLabel}"
                                Tag="{Binding}"
                                Visibility="{Binding ActionVisibility}"
                                Style="{StaticResource PrimaryButton}"
                                Padding="8,4" FontSize="11"
                                x:Name="BtnRowAction"/>
                    </DataTemplate>
                </DataGridTemplateColumn.CellTemplate>
            </DataGridTemplateColumn>
        </DataGrid.Columns>
    </DataGrid>

    <!-- Footer summary -->
    <Border Grid.Row="2" Background="#1A1A2C" Padding="16,8" BorderBrush="#3A3A55" BorderThickness="0,1,0,0">
        <TextBlock x:Name="SummaryLabel" Foreground="#9999BB" FontSize="11"
                   Text="Loading..."/>
    </Border>
</Grid>

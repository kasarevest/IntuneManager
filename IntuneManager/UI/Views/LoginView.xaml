<Grid xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#1E1E2E">
    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="380">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="32"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="20"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Center">
            <TextBlock Text="&#x2B21;" FontSize="40" Foreground="#4F8EF7" HorizontalAlignment="Center"/>
            <TextBlock Text="Intune App Manager" FontSize="22" FontWeight="Bold"
                       Foreground="#E2E2F0" HorizontalAlignment="Center" Margin="0,8,0,4"/>
            <TextBlock Text="Sign in with your Microsoft admin account to manage Intune apps"
                       Foreground="#9999BB" FontSize="12" HorizontalAlignment="Center"
                       TextWrapping="Wrap" TextAlignment="Center"/>
        </StackPanel>

        <!-- Sign in with Microsoft button -->
        <Button x:Name="BtnBrowserLogin" Grid.Row="2"
                Content="  Sign in with Microsoft"
                Height="46" Style="{StaticResource PrimaryButton}"/>

        <!-- Device code button -->
        <Button x:Name="BtnDeviceCode" Grid.Row="4"
                Content="  Sign in with Device Code (no browser)"
                Height="38" Style="{StaticResource SecondaryButton}"/>

        <!-- Status -->
        <Border Grid.Row="6" Background="#1A1A2C" CornerRadius="5" Padding="10,8"
                x:Name="StatusPanel" Visibility="Collapsed">
            <TextBlock x:Name="LoginStatus" Text="" Foreground="#9999BB"
                       FontSize="12" TextWrapping="Wrap" TextAlignment="Center"/>
        </Border>
    </Grid>
</Grid>

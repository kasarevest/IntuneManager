# ── Application ───────────────────────────────────────────────────────────────
APP_SECRET_KEY=change-me-to-a-random-32-char-secret
PORT=3001
NODE_ENV=development

# Production URL of the deployed app (used for CORS allowlist)
# APP_ORIGIN=https://<container-app-name>.eastus.azurecontainerapps.io

# ── Database ──────────────────────────────────────────────────────────────────
# Azure SQL Serverless (production)
# NOTE: connectionTimeout=60 and loginTimeout=60 are required because Azure SQL
# Serverless auto-pauses after 60 min of inactivity and takes up to 60s to resume.
# DATABASE_URL=sqlserver://<server>.database.windows.net:1433;database=intunemanager;user=<user>;password=<pwd>;encrypt=true;trustServerCertificate=false;connectionTimeout=60;loginTimeout=60

# Local SQL Server for development
# DATABASE_URL=sqlserver://localhost:1433;database=intunemanager;user=sa;password=<pwd>;trustServerCertificate=true

# ── AI Integration ────────────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-...

# ── Azure Storage (Phase 3+) ──────────────────────────────────────────────────
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...

# ── Microsoft Graph API (Phase 3) ────────────────────────────────────────────
# App Registration in Azure AD (portal.azure.com > App registrations > IntuneManager Web)
# Required delegated permissions: DeviceManagementApps.ReadWrite.All,
#   DeviceManagementConfiguration.Read.All, User.Read
# Redirect URI must match exactly: <APP_ORIGIN>/api/auth/ms-callback
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=your-client-secret
AZURE_REDIRECT_URI=http://localhost:3001/api/auth/ms-callback
